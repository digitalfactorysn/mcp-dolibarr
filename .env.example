# ──────────────────────────────────────────────────────
# MCP Dolibarr — Configuration
# Digital Factory Senegal — https://digitalfactory.sn
# ──────────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs

# ── Dolibarr ──
# URL de base de l'API REST Dolibarr
# Exemple : https://erp.digitalfactory.sn/api/index.php
DOLIBARR_URL=https://votre-dolibarr.com/api/index.php

# Clé API Dolibarr (Utilisateurs > Profil > Clé API REST)
DOLIBARR_API_KEY=votre_cle_api_dolibarr

# ── Serveur HTTP (mode http uniquement) ──
# Port d'écoute du serveur HTTP
PORT=3000

# Token d'authentification Bearer pour protéger l'endpoint /mcp
# Laissez vide pour désactiver (protégez alors par IP/VPN)
# MCP_API_TOKEN=generez_un_token_fort_ici
